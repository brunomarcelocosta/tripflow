{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "Provider": "Local",
    "ContainerName": "tenant-assets",
    "LocalBasePath": "wwwroot/uploads",
    "PublicBaseUrl": "",
    "UsePublicAccess": true
  },
  "Frontend": {
    "PublicProposalBaseUrl": "http://localhost:5044/public/proposals"
  },
  "Pdf": {
    "Enabled": true
  },
  "PaymentGateway": {
    "Asaas": {
      "Enabled": true,
      "BaseUrl": "https://api-sandbox.asaas.com/v3"
    }
  }
}
